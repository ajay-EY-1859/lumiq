{
  "name": "lumiq",
  "version": "1.0.0",
  "description": "Lumiq — One interface. Every model. An Electron desktop GUI for multi-provider AI chat.",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/ajay-EY-1859/lumiq",
  "author": "Fairline tech",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder --win --mac --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "cross-env ELECTRON_RUN_AS_NODE=true electron node_modules/vitest/vitest.mjs run",
    "test:watch": "cross-env ELECTRON_RUN_AS_NODE=true electron node_modules/vitest/vitest.mjs"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-bedrock": "^3.700.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@google/generative-ai": "^0.21.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.1",
    "@monaco-editor/react": "^4.7.0",
    "@xenova/transformers": "^2.0.1",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0",
    "monaco-editor": "^0.53.0",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.0",
    "uuid": "^11.0.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "electron": "^41.5.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
