{
  "name": "@lumiq/native",
  "version": "0.1.0",
  "description": "Lumiq high-performance native module — Rust-powered file scanning, text chunking, vector similarity, and search",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "lumiq-native",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
